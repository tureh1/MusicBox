<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <TextView
        android:id="@+id/RateAlbumText"
        android:layout_width="172dp"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="131dp"
        android:layout_marginTop="89dp"
        android:layout_marginEnd="106dp"
        android:fontFamily="@font/joan"
        android:shadowColor="@color/black"
        android:shadowRadius="10"
        android:text="Rate Albums"
        android:textColor="@color/black"
        android:textSize="25sp" />

    <EditText
        android:id="@+id/search_barAlbum"
        android:layout_width="match_parent"
        android:layout_height="43dp"
        android:layout_below="@id/RateAlbumText"
        android:layout_marginStart="16dp"
        android:layout_marginTop="-105dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/searchbar"
        android:drawableLeft="@drawable/baseline_search_24"
        android:hint="Search for Albums" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="403dp"
        android:layout_height="511dp"
        android:layout_above="@id/bottomNavigationView"
        android:layout_below="@+id/RateAlbumText"
        android:layout_marginStart="8dp"
        android:layout_marginLeft="8dp"
        android:layout_marginTop="1dp"
        android:layout_marginEnd="8dp"
        android:layout_marginRight="8dp"
        android:layout_marginBottom="6dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/LightBlue">

        <!-- Bottom Navigation Menu with Icons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/navigation_home"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:backgroundTint="#00FFFFFF"
                android:scaleType="fitCenter"
                android:src="@drawable/home" />

            <ImageButton
                android:id="@+id/navigation_adduser"
                android:layout_width="wrap_content"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:background="#00FFFFFF"
                android:scaleType="fitCenter"
                android:src="@drawable/adduser" />

            <ImageButton
                android:id="@+id/navigation_message"
                android:layout_width="wrap_content"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:background="#00FFFFFF"
                android:scaleType="fitCenter"
                android:src="@drawable/comment_alt_dots" />

            <ImageButton
                android:id="@+id/navigation_user"
                android:layout_width="wrap_content"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:background="#00FFFFFF"
                android:scaleType="fitCenter"
                android:src="@drawable/user" />

        </LinearLayout>
    </com.google.android.material.bottomnavigation.BottomNavigationView>

</RelativeLayout>
