<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".UserProfileActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- My Reviews Section -->

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="438dp">

                <View
                    android:id="@+id/view"
                    android:layout_width="431dp"
                    android:layout_height="228dp"
                    android:background="@drawable/download_1__1_"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.0" />

                <ImageView
                    android:id="@+id/avatar_profile"
                    android:layout_width="105dp"
                    android:layout_height="100dp"
                    android:layout_marginEnd="23dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.54"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.402"
                    app:srcCompat="@drawable/avatar" />

                <TextView
                    android:id="@+id/username_profile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="161dp"
                    android:layout_marginTop="15dp"
                    android:layout_marginEnd="161dp"
                    android:fontFamily="@font/joan"
                    android:text="User Name"
                    android:textColor="@color/NavyBlue"
                    android:textSize="19dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/avatar_profile" />

                <LinearLayout
                    android:id="@+id/linearLayout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginStart="119dp"
                    android:layout_marginTop="3dp"
                    android:layout_marginEnd="119dp"
                    android:fontFamily="@font/joan"
                    android:orientation="horizontal"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/username_profile">


                    <TextView
                        android:id="@+id/review_count"
                        android:layout_width="89dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="16dp"
                        android:fontFamily="@font/joan"
                        android:text="Reviews: 25" />

                    <TextView
                        android:id="@+id/friends_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/joan"
                        android:text="Friends: 150" />
                </LinearLayout>

                <EditText
                    android:id="@+id/bio_profile"
                    android:layout_width="373dp"
                    android:layout_height="62dp"
                    android:layout_margin="15dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/bio"
                    android:fontFamily="@font/joan"
                    android:gravity="center_horizontal"
                    android:hint="Sart writing your bio...."
                    android:textColor="@color/NavyBlue"
                    android:textSize="13sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/linearLayout" />


                <Button
                    android:id="@+id/save_bio_text"
                    android:layout_width="81dp"
                    android:layout_height="37dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="29dp"
                    android:backgroundTint="@color/BabyBlue"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/joan"
                    android:text="Save"
                    android:textColor="@color/NavyBlue"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/bio_profile" />

                <Button
                    android:id="@+id/delete_bio_text"
                    android:layout_width="85dp"
                    android:layout_height="35dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="@color/BabyBlue"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/joan"
                    android:text="Delete"
                    android:textColor="#BC6C6C"
                    android:textSize="12dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/bio_profile" />


            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/my_reviews_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="My Reviews"
                android:textSize="15sp"
                android:textColor="@color/NavyBlue"
                android:fontFamily="@font/joan" />

            <LinearLayout
                android:id="@+id/my_reviews"
                android:layout_width="wrap_content"
                android:layout_height="120dp"
                android:layout_marginTop="5dp"
                android:gravity="center"
                android:orientation="horizontal">

                <!-- Review 1 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="5dp"

                    android:orientation="vertical"
                    android:padding="5dp">

                    <TextView
                        android:id="@+id/review_1_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/joan"
                        android:text="Song Title 1"
                        android:textColor="@color/NavyBlue"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/review_1_artist"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Artist 1"
                        android:textColor="#666666"
                        android:textSize="16sp"
                        android:fontFamily="@font/joan"/> <!-- Grey color for artist name -->

                    <TextView
                        android:id="@+id/review_1_rating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rating: ★★★★☆"
                        android:textSize="16sp"
                        android:fontFamily="@font/joan"/>
                </LinearLayout>

                <!-- Review 2 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="5dp"
                    android:layout_marginStart="5dp"
                    android:orientation="vertical"
                    android:padding="5dp">

                    <TextView
                        android:id="@+id/review_2_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/joan"
                        android:text="Song Title 2"
                        android:textColor="@color/NavyBlue"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/review_2_artist"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Artist 2"
                        android:textColor="#666666"
                        android:textSize="16sp"
                        android:fontFamily="@font/joan"/>

                    <TextView
                        android:id="@+id/review_2_rating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rating: ★★★☆☆"
                        android:fontFamily="@font/joan"/>
                </LinearLayout>

                <!-- Review 3 -->
                <LinearLayout
                    android:layout_width="148dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="5dp">

                    <TextView
                        android:id="@+id/review_3_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/joan"
                        android:text="Song Title 3"
                        android:textColor="@color/NavyBlue"
                        android:textSize="18sp"/>

                    <TextView
                        android:id="@+id/review_3_artist"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Artist 3"
                        android:textColor="#666666"
                        android:textSize="16sp"
                        android:fontFamily="@font/joan"/>

                    <TextView
                        android:id="@+id/review_3_rating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rating: ★★★★★"
                        android:fontFamily="@font/joan"/>

                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/LightBlue"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/home"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:backgroundTint="#00FFFFFF"
                android:scaleType="fitCenter"
                android:src="@drawable/home" />

            <ImageButton
                android:id="@+id/adduser"
                android:layout_width="wrap_content"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:background="#00FFFFFF"
                android:scaleType="fitCenter"
                android:src="@drawable/adduser" />

            <ImageButton
                android:id="@+id/message"
                android:layout_width="wrap_content"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:background="#00FFFFFF"
                android:scaleType="fitCenter"
                android:src="@drawable/comment_alt_dots" />

            <ImageButton
                android:id="@+id/user"
                android:layout_width="wrap_content"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:background="#00FFFFFF"
                android:scaleType="fitCenter"
                android:src="@drawable/user" />
        </LinearLayout>
    </com.google.android.material.bottomnavigation.BottomNavigationView>

</androidx.constraintlayout.widget.ConstraintLayout>
